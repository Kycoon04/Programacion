#include <iostream> //Jose
using namespace std;
class libro{
private:
	string autor;
	string titulo;
	string genero;
	bool disponible;
public:
	Libro () {
		autor = "null";
		titulo = "null";
		genero = "null";
		disponible = false;
	}
	Libro (string autor, string titulo, string genero, bool disponible){
		this->autor = autor;
		this->titulo = titulo;
		this->genero = genero;
		this->disponible = disponible;
	}
	void setLibro(string autor, string titulo, string genero, bool diponible){
		this->autor = autor;
		this->titulo = titulo;
		this->genero = genero;
		this->disponible = disponible;
	}
	void setAutor(string autor){
		this->autor = autor;
	}
	string getAutor(){
		return (autor);
	}
	void setTitulo(string titulo){
		this->titulo = titulo;
	}
	string getTitulo(){
		return (titulo);
	}
	void setGenero(string pgenero){
		genero = pgenero;
	}
	string getGenero(){
		return (genero);
	}
	
};
