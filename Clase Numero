#include <iostream>
#include <math.h>
using namespace std;
class Numero {		
private:
int valor;
public:
	Numero () {
		valor = 0;
	}
	Numero (int valor)   
	{    this->valor = valor; }
	void setValor (int valor)
	{
		this->valor = valor;
	}
	int getValor ( )
	{
		return(valor);
	}
	~ Numero (){
	}
	bool esImpar ()
	{
		if (valor %2 != 0)
			return true;
	    else 
			return false;
	}
	string esImpar1 ()
	{
		if (valor %2 != 0)
			return "impar";
		else
			return "par";
	}
	int absoluto()
	{ 
		if(valor>=0) 
			return  valor; 
		else 
			return (-valor); 
	} 
	void NumMen() {
		
		for(int i=1; i<valor; i++) 
			cout<<i<<" ";
	}
	void NumPares() {
		for (int i=1; i <valor; i++) 
		if (i%2 ==0) 
			cout<<i<<" "; 
	}
	
	
} ;

