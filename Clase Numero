	int a;
	int b;
	int c;
	 cout<<"Valor del numero: "<<endl; 
	 cin>>a;
	Numero num1(a);
	if (num1.esImpar()) {
	cout<<"El numero es impar"<<endl<<endl;
	}else{
	cout<<"El numero es par"<<endl<<endl;
	}
	cout<<"Valor del numero: "<<endl<<endl;
	cin>>b;
	num1.setValor(b);
	cout<<"El numero es "<<num1.esImpar1()<<endl;
	
	cout<<"Digite un nuevo valor:"<<endl;
	cin>>c;
	num1.setValor(c);
	cout<<"El valor absoluto es: "<<num1.absoluto()<<endl;
	cout<<"Los numeros anteriores son: "<<num1.getValor()<<endl;
	num1.NumMen(); 
	num1.setValor(c);
	
	cout<<endl<<"Los numeros anteriores pares son: "<<num1.getValor()<<endl;
	num1.NumPares();
	
	cout<<"El valor que tengo agregado:"<<num1.getValor()<<endl;
  return 0;
}
	
