#include <iostream>
#include <math.h>
using namespace std;
class Numero {		
private:
	int valor;
public:
	Numero () {
		valor = 0;
	}
	Numero (int valor)   
	{    this->valor = valor; }
	void setValor (int valor)
	{
		this->valor = valor;
	}
	int getValor ( )
	{
		return(valor);
	}
	~ Numero (){
	}
	bool esImpar ()
	{
		if (valor %2 != 0)
			return true;
		else 
			return false;
	}
	string esImpar1 ()
	{
		if (valor %2 != 0)
			return "impar";
		else
			return "par";
	}
	int absoluto()
	{ 
		if(valor>=0) 
			return  valor; 
		else 
			return (-valor); 
	} 
	void NumMen() {
		
		for(int i=1; i<valor; i++) 
			cout<<i<<" ";
	}
	void NumPares() {
		for (int i=1; i <valor; i++) 
		if (i%2 ==0) 
			cout<<i<<" "; 
	}
	void divisores () {
		int i=1; 
		while(i <= valor) {
			if (valor % i ==0)
				cout<<i<<endl;
		i++;
		}
	}
	int sumDivisoresPropios()
	{
		int suma=0;
		int i=1;
		
		while(i <= valor)
			if (valor % i ==0)
				suma=suma+i;
		i++;
		return suma;
	}
	bool perfecto () 
	{
		if (sumDivisoresPropios()== valor)
			return(true);
		else
			return(false);
	}
	
} ;

int main(int argc, char *argv[]) {
	int a;
	int c;
	cout<<"Valor del numero: "<<endl; 
	cin>>a;
	Numero num1(a);
	if (num1.esImpar()) {
		cout<<"El numero es impar"<<endl<<endl;
	}else{
		cout<<"El numero es par"<<endl<<endl;
	}
	
	cout<<"Digite un nuevo valor:"<<endl;
	cin>>c;
	cout<<"Los numeros anteriores son: "<<num1.getValor()<<endl;
	num1.NumMen(); 
	num1.setValor(c);
	
	cout<<endl<<"Los numeros anteriores pares son: "<<num1.getValor()<<endl;
	num1.NumPares(); 
	
	cout<<"El entrenador puede hacer filas de "<<endl;
	num1.divisores(); 
	
	cout<<"Voy a mandar a pantalla el valor "<<num1.getValor();
	if (num1.perfecto()) 
		cout<<"El numero "<<num1.getValor()<<" es perfecto "<<endl; 
	else 
		cout<<"El numero "<<num1.getValor()<<" NO es perfecto "<<endl; 
	
	
	
	return 0;
}
