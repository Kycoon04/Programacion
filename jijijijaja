#include <iostream>
using namespace std;

class Fecha {
private:
	int dia;
	int mes;
	int anyo;
	
public:
	Fecha (){
		dia = 0;
		mes = 0;
		anyo = 0;
	}
	Fecha (int dia, int mes, int anyo){
		this ->dia = dia;
		this ->mes = mes;
		this ->anyo = anyo;
	}
		void setDia (int dia)
		{
			this->dia = dia;
		}
		void setMes (int mes)
		{
			this->mes = mes;
		}
		void setAnyo (int anyo)
		{
			this->anyo = anyo;
		}
		int getDia ( )
		{
			return(dia);
		}
		int getMes ( )
		{
			return(mes);
		}
		int getAnyo ( )
		{
			return(anyo);
		}
		string mesAnyo()
		{
			switch (mes) {
			case 1: return "enero";
			case 2: return "febrero";
			case 3: return "marzo";
			case 4: return "abril";
			case 5: return "mayo";
			case 6: return "junio";
			case 7: return "julio";
			case 8: return "agosto";
			case 9: return "septiembre";
			case 10: return "octubre";
			case 11: return "noviembre";
			case 12: return "diciembre";  
			default: return "mes invalido"; 
			}
		}
		bool bisiesto(){
			if((anyo%4 == 0) && (anyo%100 != 0 || anyo%400 == 0))
				return true;
			else
				return false;
		 }
		int  diasMes() {
			if (mes == 4 || mes == 6 || mes == 9 || mes == 11)
				return 30;
			else
				if (mes == 2)
					if ( bisiesto( ) ) 
						return 29;
					else 
						return 28;
				else
					return 31;
		}
		void incrementaDia() 	
		{
			int Nu; 
			
			cout<<endl<<"Cuantos dias quiere sumarle: ";
			cin>> Nu;
			
		for(int i=1; i <=Nu; i++) {
			if (dia < diasMes()) {
				dia++;
			}
			else  {  
				dia = 1;
				if (mes < 12)
					mes++;
				else  {
					mes = 1;
					anyo++;
				}
			}
		}
		}
		void DisminuirDia() 	
		{
			int Nu; 
			
			cout<<endl<<"Cuantos dias quiere restarle: ";
			cin>> Nu;
			
			for(int i=1; i <=Nu; i++) {
			if (dia > 0)
				dia--;
			else  { 
				if (mes > 0)
					mes--;
				else  {
					mes = 1;
					anyo--;
				}
				dia = diasMes();
			}
			}
		}
		void Seleccion (int resp) 
		{
			switch (resp) {
			case 1: incrementaDia();break;
			case 2: DisminuirDia();break;
			default: cout<<"ingrese un valor correcto";break;
			}
		}
		void  imprimeFecha (){
			cout << dia<< "de "<<mesAnyo() << "de " << anyo << endl;
		}
		
};
int main(int argc, char *argv[]) {
	
	int dia = 0;
	int mes = 0;
	int anyo = 0;
	int resp = 0; 
	
	
	cout<<"Introduzca el numero de dia: ";
	cin>>dia; 
	cout<<"Introduzca el numero de mes: ";
	cin>>mes; 
	cout<<"Introduzca el numero de año: ";
	cin>>anyo; 
	 Fecha m(dia,mes,anyo);
	 
	 
	 cout<<endl<<"Su mes en palabra es: "<<m.mesAnyo();
	 
	 if (m.bisiesto())
		cout<<endl<<endl<<"El año es bisiesto";
	 else 
		cout<<endl<<endl<<"El año no es bisiesto";
	 
	 cout<<endl<<endl<<"Su mes tiene: "<<m.diasMes()<<" días";
	 
	 cout<<endl<<"Seleccione 1 para Aumentar y 2 Para disminuir: ";
	 cin>>resp;
	 m.imprimeFecha();
	 m.Seleccion(resp);
	 m.imprimeFecha();
	 
	return 0;
}


