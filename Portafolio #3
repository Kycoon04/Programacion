#include <iostream>
using namespace std;

class ViajeTren { 
private: 
	bool asientos[10]; 
	int tamano; 
	int cantidad; 
public:
	
ViajeTren() { 
	cantidad=0; 
	tamano= 10; 
	for(int i=0;i< tamano;i++)
	asientos[i]=0;
}
	
ViajeTren(int n) { 
	cantidad=0; 
	tamano= n; 
	for(int i=0;i< tamano;i++)
	asientos[i]=0;
}
	
int getCantidad(){
	return cantidad;
}
	
int getTamano(){ 
	return tamano; 
}
	
void setCantidad(int can){  
	if ((can < tamano)&&(can >0))
	cantidad = can;      
}
	
void setTamano(int ptamano){ 
	tamano = ptamano; 
} 
	
void insertarElemento(int elem ) { 
	if (cantidad < tamano)
	{	asientos[cantidad]=elem; 
	setCantidad(cantidad+1); 
	}
}

void Reservar(int asiento){
		if (asientos[asiento]==asiento) {
			cout<<endl<<"El asiento se encuentra ocupado"<<endl;
	}
	else {
		asientos[asiento] = true; 
		cout<<endl<<"Se reservo su asiento satifactoriamente"<<endl; 
	}
}
	
int Reservas(){
	int cant = 0;
	for(int i = 0; i < 10; i++){
		if(asientos[i] == true)
			cant++;
	}
	return cant;
}
	
void hacerReserva(){
	for(int i = 0; i < 10; i++){
		if(asientos[i] == false){
			cout<<i;
			if(i % 2 == 0)
				cout<<" Asiento Con Electricidad"<<endl<<endl;
			else
				cout<<" Asiento Sin Electricidad"<<endl<<endl;
		}
	}
	int asiento = 0;
	cout<<"Ingrese el numero del asiento en el que desea estar: ";
	cin>>asiento;
	Reservar(asiento);
	}

int canAsientosreservadosConElectricidad() {
int cant = 0;
	for(int i = 0; i < 10; i++){
		if(asientos[i] == true && i % 2 == 0)
			cant++;
	}
	return cant;
}

int canAsientosreservadosSinElectricidad(){
int cant = 0;
	for(int i = 0; i < 10; i++){
		if(asientos[i] == true && i % 2 != 0)
			cant++;
	}
	return cant;
}
	
void compara(ViajeTren obj){
	int estasReservas = Reservas(), otrasReservas = obj.Reservas();
	if(estasReservas > otrasReservas)
		cout<<"El tren 1 tiene mas reservas"<<endl;
	else if(estasReservas < otrasReservas)
		cout<<"El tren 2 tiene mas reservas"<<endl;
	else
		cout<<"Ambos tienen la misma cantidad de reservas"<<endl;
}
};

