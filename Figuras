#include <iostream>
using namespace std;

int main(int argc, char *argv[]) {
	float La;
	float Ba;
	float Al;
	float Ra;
	char Res = 's';
	int opcion;
	

	while (Res == 's' or Res == 'S') {
		cout<<endl<<"---------------MENU 1° EXAMEN----------------"<<endl;
		cout<<"---------------------------------------------"<<endl<<endl;
		cout<<"..................Cuadrado.................(1)"<<endl;
		cout<<"................ Rectangulo................(2)"<<endl;
		cout<<"..................Circulo..................(3)"<<endl;
		cout<<"...................Salir...................(4)"<<endl;
		cout<<endl<<"Elija el proceso que quiera reaizar: ";
		cin>>opcion;
		
		switch(opcion){
		case 1: 
			cout<<"Digite el lado de su cuadraro: ";
			cin>>La;
			
			cout<<endl<<"El Area de su cuadrado es: "<<La*La<<endl;
			cout<<endl<<"El Perimetro de su cuadrado es: "<<La+La+La+La<<endl; break;
		case 2: 
			cout<<"Digite la base de su rectangulo: ";
			cin>>Ba;
			
			cout<<"Digite la altura de su rectangulo: ";
			cin>>Al;
			
			cout<<endl<<"El Area de su rectangulo es: "<<Ba*Al<<endl;
			cout<<endl<<"El Perimetro de su rectangulo es: "<<(Ba*2)+(Al*2)<<endl; break;
		case 3:
			cout<<"Digite el radio de su circulo: ";
			cin>>Ra;
			
			cout<<endl<<"El Area de su circulo es: "<<3.1416*Ra*Ra<<endl;
			cout<<endl<<"El Perimetro de su rectangulo es: "<<2*3.1416*Ra<<endl; break;
		case 4: 
			cout<<endl<<"Usted ha salido del sistema"<<endl<<endl;exit (0);
		default: 
			cout<<endl<<"Ingrese un valor correcto"<<endl<<endl;
		}
		std::cin.clear();
		cout<<endl<<"¿Desea volver al menu principal?  (S) (N): ";
		cin>>Res;
		system("cls");
		
	}
	cout<<endl<<"Gracias por usar los servicios de este menú espero que vuelvas pronto"<<endl<<endl;
	return 0;
}
